model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: nl-NL
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_ProTooling = ["MCP-PBIModeling"]

annotation PBI_QueryOrder = ["FactInternetSales","DimCustomer","DimDate","DimProduct","DimProductSubcategory","DimProductCategory","DimSalesTerritory","DimEmployee","FactResellerSales","FactSalesQuota","ChurnScores","CampaignActions"]

ref table FactInternetSales
ref table DimCustomer
ref table DimDate
ref table DimProduct
ref table DimProductSubcategory
ref table DimProductCategory
ref table DimSalesTerritory
ref table DimEmployee
ref table FactResellerSales
ref table FactSalesQuota
ref table ChurnScores
ref table CampaignActions
ref table RFM_Customers
ref table RFM_SegmentSummary
ref table _Measures

ref cultureInfo en-US

