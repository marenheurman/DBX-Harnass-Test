/// Customer-level RFM scores with churn risk — one row per customer
table RFM_Customers

	column CustomerKey
		dataType: int64
		isNameInferred
		isDataTypeInferred
		sourceColumn: [CustomerKey]

	column CustomerName
		dataType: string
		isNameInferred
		isDataTypeInferred
		sourceColumn: [CustomerName]

	column Occupation
		dataType: string
		isNameInferred
		isDataTypeInferred
		sourceColumn: [Occupation]

	column Segment
		dataType: string
		isNameInferred
		isDataTypeInferred
		sourceColumn: [Segment]

	column Recency
		dataType: int64
		isNameInferred
		isDataTypeInferred
		sourceColumn: [Recency]

	column Frequency
		dataType: int64
		isNameInferred
		isDataTypeInferred
		sourceColumn: [Frequency]

	column TotalSpend
		dataType: double
		isNameInferred
		isDataTypeInferred
		sourceColumn: [TotalSpend]

	column AvgOrderValue
		dataType: double
		isNameInferred
		isDataTypeInferred
		sourceColumn: [AvgOrderValue]

	column ChurnRiskScore
		dataType: double
		isNameInferred
		isDataTypeInferred
		sourceColumn: [ChurnRiskScore]

	column RiskBand
		dataType: string
		isNameInferred
		isDataTypeInferred
		sourceColumn: [RiskBand]

	partition RFM_Customers = calculated
		mode: import
		source =
				SELECTCOLUMNS(
				    ChurnScores,
				    "CustomerKey",    ChurnScores[CustomerKey],
				    "CustomerName",   ChurnScores[FirstName] & " " & ChurnScores[LastName],
				    "Occupation",     ChurnScores[Occupation],
				    "Segment",        ChurnScores[Segment],
				    "Recency",        ChurnScores[Recency],
				    "Frequency",      ChurnScores[Frequency],
				    "TotalSpend",     ChurnScores[TotalSpend],
				    "AvgOrderValue",  ChurnScores[AvgOrderValue],
				    "ChurnRiskScore", ChurnScores[ChurnRiskScore],
				    "RiskBand",       ChurnScores[RiskBand]
				)

