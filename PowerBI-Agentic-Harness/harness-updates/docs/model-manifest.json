{
  "_meta": {
    "description": "Machine-readable manifest of all tables, columns, and measures in the CRM Decision Intelligence semantic model. Used by agents to resolve exact field names when building reports or writing DAX, without needing a live MCP connection.",
    "model": "CRM Decision Intelligence",
    "last_updated": "2026-03-31",
    "canvas_width": 1280,
    "canvas_height": 720
  },
  "measures_table": "_Measures",
  "measures": [
    { "name": "Total Internet Sales",     "folder": "Sales",    "format": "currency" },
    { "name": "Total Reseller Sales",     "folder": "Sales",    "format": "currency" },
    { "name": "Total Sales",              "folder": "Sales",    "format": "currency" },
    { "name": "Sales Quota",              "folder": "Sales",    "format": "currency" },
    { "name": "Quota Attainment %",       "folder": "Sales",    "format": "percent" },
    { "name": "YoY Growth %",             "folder": "Sales",    "format": "percent" },
    { "name": "Total Customers",          "folder": "Customer", "format": "integer" },
    { "name": "New Customers",            "folder": "Customer", "format": "integer" },
    { "name": "Repeat Purchase Rate %",   "folder": "Customer", "format": "percent" },
    { "name": "Avg Order Value",          "folder": "Customer", "format": "currency" },
    { "name": "Churn Rate %",             "folder": "Churn",    "format": "percent" },
    { "name": "At Risk Customers",        "folder": "Churn",    "format": "integer" },
    { "name": "Revenue at Risk",          "folder": "Churn",    "format": "currency" },
    { "name": "Avg Churn Score",          "folder": "Churn",    "format": "decimal" },
    { "name": "Model Accuracy",           "folder": "Churn",    "format": "percent" },
    { "name": "Total Customers Analysed", "folder": "Churn",    "format": "integer" },
    { "name": "High Risk Count",          "folder": "Churn",    "format": "integer" },
    { "name": "Total Actions",            "folder": "Campaign", "format": "integer" },
    { "name": "P1 Urgent Actions",        "folder": "Campaign", "format": "integer" },
    { "name": "Estimated Recovery Value", "folder": "Campaign", "format": "currency" },
    { "name": "Revenue Recovery Rate %",  "folder": "Campaign", "format": "percent" },
    { "name": "Champions",                "folder": "RFM",      "format": "integer" },
    { "name": "Loyal Customers",          "folder": "RFM",      "format": "integer" },
    { "name": "At Risk Segment Count",    "folder": "RFM",      "format": "integer" },
    { "name": "Avg RFM Score",            "folder": "RFM",      "format": "decimal" },
    { "name": "Avg RFM Churn Risk",       "folder": "RFM",      "format": "decimal" }
  ],
  "tables": [
    {
      "name": "FactInternetSales",
      "type": "fact",
      "columns": [
        "SalesOrderNumber", "OrderDate", "DueDate", "ShipDate",
        "CustomerKey", "ProductKey", "SalesTerritoryKey",
        "SalesAmount", "TaxAmt", "Freight", "OrderQuantity",
        "UnitPrice", "ExtendedAmount", "DiscountAmount",
        "TotalProductCost", "StandardProductCost"
      ]
    },
    {
      "name": "FactResellerSales",
      "type": "fact",
      "columns": [
        "SalesOrderNumber", "OrderDate", "DueDate", "ShipDate",
        "ResellerKey", "EmployeeKey", "ProductKey", "SalesTerritoryKey",
        "SalesAmount", "TaxAmt", "Freight", "OrderQuantity",
        "UnitPrice", "ExtendedAmount", "DiscountAmount",
        "TotalProductCost", "StandardProductCost"
      ]
    },
    {
      "name": "FactSalesQuota",
      "type": "fact",
      "columns": [
        "SalesQuotaKey", "EmployeeKey", "DateKey",
        "CalendarYear", "CalendarQuarter", "SalesAmountQuota"
      ]
    },
    {
      "name": "DimCustomer",
      "type": "dimension",
      "columns": [
        "CustomerKey", "GeographyKey", "CustomerAlternateKey",
        "Title", "FirstName", "MiddleName", "LastName", "NameStyle",
        "BirthDate", "MaritalStatus", "Suffix", "Gender",
        "EmailAddress", "YearlyIncome", "TotalChildren",
        "NumberChildrenAtHome", "EnglishEducation", "SpanishEducation",
        "FrenchEducation", "EnglishOccupation", "SpanishOccupation",
        "FrenchOccupation", "HouseOwnerFlag", "NumberCarsOwned",
        "AddressLine1", "AddressLine2", "Phone", "DateFirstPurchase",
        "CommuteDistance", "Occupation"
      ]
    },
    {
      "name": "DimDate",
      "type": "dimension",
      "mark_as_date_table": true,
      "date_column": "FullDateAlternateKey",
      "columns": [
        "DateKey", "FullDateAlternateKey", "DayNumberOfWeek",
        "EnglishDayNameOfWeek", "SpanishDayNameOfWeek", "FrenchDayNameOfWeek",
        "DayNumberOfMonth", "DayNumberOfYear", "WeekNumberOfYear",
        "EnglishMonthName", "SpanishMonthName", "FrenchMonthName",
        "MonthNumberOfYear", "CalendarQuarter", "CalendarYear",
        "CalendarSemester", "FiscalQuarter", "FiscalYear", "FiscalSemester",
        "Year", "Month Number", "Week Number", "Day of Week",
        "Is Weekend", "Month Year"
      ],
      "notes": "Year, Month Number, Week Number, Day of Week, Is Weekend, Month Year are calculated columns added during model build."
    },
    {
      "name": "DimProduct",
      "type": "dimension",
      "columns": [
        "ProductKey", "ProductAlternateKey", "ProductSubcategoryKey",
        "WeightUnitMeasureCode", "SizeUnitMeasureCode", "EnglishProductName",
        "SpanishProductName", "FrenchProductName", "StandardCost",
        "FinishedGoodsFlag", "Color", "SafetyStockLevel", "ReorderPoint",
        "ListPrice", "Size", "SizeRange", "Weight", "DaysToManufacture",
        "ProductLine", "DealerPrice", "Class", "Style", "ModelName",
        "Description", "StartDate", "EndDate", "Status"
      ]
    },
    {
      "name": "DimProductSubcategory",
      "type": "dimension",
      "columns": [
        "ProductSubcategoryKey", "ProductCategoryKey",
        "EnglishProductSubcategoryName", "SpanishProductSubcategoryName",
        "FrenchProductSubcategoryName"
      ]
    },
    {
      "name": "DimProductCategory",
      "type": "dimension",
      "columns": [
        "ProductCategoryKey",
        "EnglishProductCategoryName", "SpanishProductCategoryName",
        "FrenchProductCategoryName"
      ]
    },
    {
      "name": "DimSalesTerritory",
      "type": "dimension",
      "columns": [
        "SalesTerritoryKey", "SalesTerritoryAlternateKey",
        "SalesTerritoryRegion", "SalesTerritoryCountry", "SalesTerritoryGroup",
        "Region", "Country", "Group"
      ]
    },
    {
      "name": "DimEmployee",
      "type": "dimension",
      "columns": [
        "EmployeeKey", "ParentEmployeeKey", "EmployeeNationalIDAlternateKey",
        "ParentEmployeeNationalIDAlternateKey", "SalesTerritoryKey",
        "FirstName", "LastName", "MiddleName", "NameStyle",
        "Title", "HireDate", "BirthDate", "LoginID", "EmailAddress",
        "Phone", "MaritalStatus", "EmergencyContactName",
        "EmergencyContactPhone", "SalariedFlag", "Gender", "PayFrequency",
        "BaseRate", "VacationHours", "SickLeaveHours", "CurrentFlag",
        "SalesPersonFlag", "DepartmentName", "StartDate", "EndDate", "Status"
      ]
    },
    {
      "name": "ChurnScores",
      "type": "ml",
      "description": "ML model output — one row per customer with churn probability scores",
      "columns": [
        "CustomerKey", "CustomerName", "EmailAddress", "Occupation",
        "YearlyIncome", "ChurnProbability", "RiskBand",
        "Segment", "PredictedRevenueLoss", "ModelVersion", "ScoreDate"
      ],
      "notes": "RiskBand values: Low, Medium, High, Critical. Segment values: Champions, Loyal Customers, At Risk, Lost."
    },
    {
      "name": "CampaignActions",
      "type": "ml",
      "description": "AI-generated next-best-action recommendations per customer",
      "columns": [
        "ActionKey", "CustomerKey", "CustomerName", "ActionType",
        "ActionChannel", "Priority", "EstimatedRecoveryValue",
        "ActionStatus", "CreatedDate", "TargetDate", "CompletedDate"
      ],
      "notes": "Priority values: P1-Urgent, P2-High, P3-Medium. ActionStatus values: Pending, In Progress, Completed, Cancelled. ActionChannel values: Email, Phone, SMS, In-App."
    },
    {
      "name": "RFM_Customers",
      "type": "ml",
      "description": "Recency, Frequency, Monetary scoring per customer",
      "columns": [
        "CustomerKey", "RecencyScore", "FrequencyScore", "MonetaryScore",
        "RFMScore", "RFMSegment", "ChurnRiskScore", "LastPurchaseDate"
      ]
    },
    {
      "name": "RFM_SegmentSummary",
      "type": "ml",
      "description": "Aggregated RFM segment summary",
      "columns": [
        "RFMSegment", "CustomerCount", "AvgRecency",
        "AvgFrequency", "AvgMonetary", "AvgChurnRisk"
      ]
    }
  ],
  "relationships": [
    { "from": "FactInternetSales.CustomerKey",     "to": "DimCustomer.CustomerKey",             "cardinality": "many-to-one" },
    { "from": "FactInternetSales.ProductKey",       "to": "DimProduct.ProductKey",               "cardinality": "many-to-one" },
    { "from": "FactInternetSales.SalesTerritoryKey","to": "DimSalesTerritory.SalesTerritoryKey", "cardinality": "many-to-one" },
    { "from": "FactInternetSales.OrderDate",        "to": "DimDate.FullDateAlternateKey",        "cardinality": "many-to-one" },
    { "from": "FactResellerSales.ProductKey",       "to": "DimProduct.ProductKey",               "cardinality": "many-to-one" },
    { "from": "FactResellerSales.SalesTerritoryKey","to": "DimSalesTerritory.SalesTerritoryKey", "cardinality": "many-to-one" },
    { "from": "FactResellerSales.OrderDate",        "to": "DimDate.FullDateAlternateKey",        "cardinality": "many-to-one" },
    { "from": "FactResellerSales.EmployeeKey",      "to": "DimEmployee.EmployeeKey",             "cardinality": "many-to-one" },
    { "from": "FactSalesQuota.EmployeeKey",         "to": "DimEmployee.EmployeeKey",             "cardinality": "many-to-one" },
    { "from": "DimProduct.ProductSubcategoryKey",   "to": "DimProductSubcategory.ProductSubcategoryKey", "cardinality": "many-to-one" },
    { "from": "DimProductSubcategory.ProductCategoryKey", "to": "DimProductCategory.ProductCategoryKey", "cardinality": "many-to-one" },
    { "from": "ChurnScores.CustomerKey",            "to": "DimCustomer.CustomerKey",             "cardinality": "many-to-one" },
    { "from": "CampaignActions.CustomerKey",        "to": "DimCustomer.CustomerKey",             "cardinality": "many-to-one" },
    { "from": "RFM_Customers.CustomerKey",          "to": "DimCustomer.CustomerKey",             "cardinality": "many-to-one" }
  ]
}
